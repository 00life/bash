#!/bin/bash

API="https://raw.githubusercontent.com/00life/bash/refs/heads/master/raspberrypi_remote";
URL_PI="http://192.168.2.24:8112/json"
CODE=$(mktemp); curl -sL $API -o ${CODE};
PATH_LOG=${HOME}/github.log;

#/ [ Deluge torrent commands ]
#/ ---------------------------
#/ curl -b cookie_deluge.txt -d '{"method": "core.add_torrent_magnet", "params": ["<magnet_uri_here>", {}], "id": 1}' http://localhost:8112/json
#/ curl -b cookie_deluge.txt -d '{"method": "web.connected", "params": [], "id": 1}' http://localhost:8112/json
#/ curl -b cookie_deluge.txt -d '{"method": "web.add_torrents", "params": [[{"path":"/path/to/your/torrent/file.torrent", "options":null}]], "id": 1}' http://localhost:8112/json
#/ curl -b cookie_deluge.txt -d '{"method": "web.get_torrent_files", "params": ["<torrent_id_here>"], "id": 1}' http://localhost:8112/json

CURL_COOKIE=$(mktemp --suffix=".txt");
curl -c $CURL_COOKIE --compressed -H "Content-Type: application/json" -d '{"method": "auth.login", "params": ["pi"], "id": 1}' ${URL_PI};

MAGNET=''
COMMAND=$(cat <<EOF | tr '\n' ' '
  curl -b "$CURL_COOKIE"
  -X POST
  -H "Content-Type: application/json" 
  -H "Accept: application/json"
  -d '{"method": "core.add_torrent_magnet", "params": ["$MAGNET", {}], "id": 1}'
  --compressed 
  $URL_PI
EOF
)


func_clean() {
  sudo rm -rf /tmp/*;
  unset API URL_PI CODE PATH_LOG CURL_COOKIE MAGNET COMMAND;
};


func_compare() {

  if [[ ! -f $PATH_LOG ]]; then
    # echo "File does not exit. Creating github.log.  Exit 1";
    echo "" > $PATH_LOG;
    func_clean
    exit 1

  elif cmp -s "$CODE" "$PATH_LOG"; then
    # echo "Files are identical. Exit 1";
    func_clean
    exit 1

  else
    # echo "Files are different.  Exit 0";
    cat $CODE > $PATH_LOG;
    eval $COMMAND;
    func_clean
	exit 0
  fi
};

func_compare;
